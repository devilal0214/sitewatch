# ================================
# JV SiteWatch Backend Environment
# ================================

# Application
NODE_ENV=production
PORT=3001
APP_NAME="JV SiteWatch DevOps"
APP_URL=https://api.jvsitewatch.com

# Database
DATABASE_URL=postgresql://sitewatch:strongpassword@postgres:5432/sitewatch_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispassword

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=30d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=alerts@youragency.com
SMTP_PASS=your-smtp-password
EMAIL_FROM="JV SiteWatch <alerts@youragency.com>"

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring intervals (milliseconds)
UPTIME_CHECK_INTERVAL=60000
SSL_CHECK_INTERVAL=3600000
DOMAIN_CHECK_INTERVAL=86400000
SERVER_CHECK_INTERVAL=60000

# Alert thresholds
SSL_EXPIRY_WARNING_DAYS=15
DOMAIN_EXPIRY_WARNING_DAYS=30
BACKUP_MAX_AGE_HOURS=24
RESPONSE_TIME_WARNING_MS=3000
CPU_WARNING_THRESHOLD=80
RAM_WARNING_THRESHOLD=85
DISK_WARNING_THRESHOLD=90

# Report
REPORT_SCHEDULE_CRON="0 8 1 * *"

# Agency Branding (for white-label reports)
AGENCY_NAME="Your Agency Name"
AGENCY_LOGO_URL=https://youragency.com/logo.png
AGENCY_WEBSITE=https://youragency.com
AGENCY_EMAIL=hello@youragency.com
AGENCY_PHONE="+1 555 000 0000"
AGENCY_ADDRESS="123 Agency Street, City, Country"
