# =============================================================================
# JV SiteWatch DevOps — Environment Configuration
# Copy this file to .env and fill in your values before deploying.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://your-domain.com
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=sitewatch
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=sitewatch
# For bare VPS (CyberPanel) use localhost; for Docker use the service name 'postgres'
DATABASE_URL=postgresql://sitewatch:change_this_strong_password@localhost:5432/sitewatch

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_this_redis_password
# For bare VPS (CyberPanel) use localhost; for Docker use the service name 'redis'
REDIS_URL=redis://:change_this_redis_password@localhost:6379

# ── JWT (generate with: openssl rand -base64 64) ─────────────────────────────
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── SMTP (Email Alerts) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="JV SiteWatch <alerts@your-domain.com>"

# ── Slack Alerts (optional) ───────────────────────────────────────────────────
# SLACK_DEFAULT_WEBHOOK=https://hooks.slack.com/services/T.../B.../xxx

# ── Telegram Alerts (optional) ────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_DEFAULT_CHAT_ID=-100xxxxxxxxxx

# ── Twilio WhatsApp (optional) ────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── OpenAI (optional — AI incident analysis) ─────────────────────────────────
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Agency Branding ───────────────────────────────────────────────────────────
AGENCY_NAME=JV Digital Agency
AGENCY_WEBSITE=https://your-agency.com

# ── Monitoring Thresholds ─────────────────────────────────────────────────────
CHECK_TIMEOUT_MS=10000
SLOW_RESPONSE_THRESHOLD_MS=3000
SSL_EXPIRY_WARNING_DAYS=30
DOMAIN_EXPIRY_WARNING_DAYS=60
CPU_WARNING_PERCENT=85
RAM_WARNING_PERCENT=90
DISK_WARNING_PERCENT=85
BACKUP_MAX_AGE_HOURS=26

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── Reports ───────────────────────────────────────────────────────────────────
# Cron for monthly report generation (default: 1st of each month at 08:00 UTC)
REPORTS_SCHEDULE_CRON=0 8 1 * *
REPORTS_OUTPUT_DIR=./reports

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-domain.com
